{
  "name": "fishspot",
  "version": "1.0.0",
  "description": "FishSpot - app para pescadores",
  "scripts": {
    "lint:html": "htmlhint src/index.html",
    "lint:css": "stylelint src/css/style.css",
    "lint:js": "eslint src/js/app.js",
    "lint": "npm run lint:html && npm run lint:css && npm run lint:js",
    "test": "jest --coverage",
    "build": "node scripts/build.js",
    "ci": "npm run lint && npm run test && npm run build",
    "start": "node src/backend/server.js"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "htmlhint": "^1.1.4",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "stylelint": "^16.3.1",
    "stylelint-config-standard": "^36.0.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "collectCoverageFrom": [
      "src/js/app.js"
    ]
  },
  "dependencies": {
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  }
}
